NODE_ENV=production

# Database Configuration
# For local development: DB_HOST=localhost
# For Docker: DB_HOST=postgres
DB_HOST=postgres
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=nestjs_clean_arch

# Server Configuration
PORT=3000

# CORS Configuration
CORS_ORIGIN=http://localhost:3000

# Authentication
AUTH_TOKEN=dev-admin-token
AUTH_READ_TOKEN=dev-read-token

# Image in Docker Hub
IMAGE_NAME=martinippo/nestjs-app
IMAGE_TAG=latest
